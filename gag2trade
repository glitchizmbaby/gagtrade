local function ekranaBildirimGonder(baslik, mesaj)
    pcall(function()
        game.StarterGui:SetCore("SendNotification", {
            Title = baslik,
            Text = tostring(mesaj),
            Duration = 15, -- Mesaj 15 saniye ekranda kalsın ki rahatça okuyabil
        })
    end)
end

-- Tüm sistemi hata yakalayıcı içine alıyoruz
local success, err = pcall(function()
    getgenv().gagconfig = getgenv().gagconfig or {}
    getgenv().gagconfig.amount = getgenv().gagconfig.amount or 1
    getgenv().gagconfig.target = getgenv().gagconfig.target or "glitchizmontop"

    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    
    -- Remote Eventi bulalım
    local targetRemote = ReplicatedStorage:WaitForChild("SharedModules"):WaitForChild("Packet"):WaitForChild("RemoteEvent")

    local amount = getgenv().gagconfig.amount
    local targetUser = getgenv().gagconfig.target

    local hedefUserId = nil
    
    local basarili, hata = pcall(function()
        hedefUserId = Players:GetUserIdFromNameAsync(targetUser)
    end)
    
    if basarili and hedefUserId then
        -- Eğer kullandığın exploit buffer desteklemiyorsa tam bu satırda hata verecek
        local buf = buffer.fromstring(
            "\251\000\"\000\000\128K\232\238\231A\028\005\001\028\v\aItemKey\v\bMushroom\v\005Count\005"
            .. string.char(amount) ..
            "\v\bCategory\v\005Seeds\000\000\000"
        )
        
        buffer.writef64(buf, 3, hedefUserId)
        
        targetRemote:FireServer(buf)
        
        ekranaBildirimGonder("BAŞARILI!", targetUser .. " adlı kişiye eşya iletildi.")
    else
        ekranaBildirimGonder("OYUNCU BULUNAMADI!", targetUser .. " isminde biri yok.")
    end
end)

-- Eğer script çökerse neden çöktüğünü ekrana yazdıracak
if not success then
    ekranaBildirimGonder("KOD HATASI VAR!", err)
end
